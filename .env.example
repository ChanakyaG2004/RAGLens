DATABASE_URL=postgresql+psycopg://raglens:raglens@localhost:5432/raglens
# Free local mode (default): sentence-transformers embeddings + Ollama generation
LOCAL_LLM_MODE=true
USE_OPENAI=false
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Optional OpenAI mode: set USE_OPENAI=true and add your API key.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K=5
